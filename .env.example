# Copy to `.env` and fill in secrets as needed.
# Do not commit `.env`.

# ------------------------------
# Weights & Biases
# ------------------------------
# Required for scripts/inference.py runs (W&B is mandatory in current pipeline).
WANDB_API_KEY=
WANDB_ENTITY=
WANDB_PROJECT=nlp2-26
WANDB_RUN_GROUP=

# ------------------------------
# Hugging Face / Model Access
# ------------------------------
# Optional unless a model requires authentication.
HF_TOKEN=

# ------------------------------
# CodeCarbon
# ------------------------------
CODECARBON_PROJECT_NAME=nlp2-26
CODECARBON_OUTPUT_DIR=outputs/codecarbon
CODECARBON_COUNTRY_ISO_CODE=NLD

# ------------------------------
# XCOMET Evaluation
# ------------------------------
# Number of GPUs used by XCOMET evaluation stage.
XCOMET_GPUS=1
